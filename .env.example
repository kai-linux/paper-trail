# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used by the agent
# PAPER_TRAIL_MODEL=anthropic:claude-sonnet-4-5

# --- Embeddings ---
# Provider: voyage (default) or openai
PAPER_TRAIL_EMBED_PROVIDER=voyage
# Optional: override the embedding model
# PAPER_TRAIL_EMBED_MODEL=voyage-3-large

# Required if PAPER_TRAIL_EMBED_PROVIDER=voyage
VOYAGE_API_KEY=pa-...

# Required if PAPER_TRAIL_EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# --- Vector store (LanceDB, embedded; just a path on disk) ---
PAPER_TRAIL_DB_PATH=./paper-trail-data
